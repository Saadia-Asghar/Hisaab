# Optional: canonical URL for invite/share links (defaults to current site origin)
# VITE_APP_PUBLIC_URL=https://your-domain.com

# Firebase (Project settings → Your apps → Web app → SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: start in demo mode on load (usually use “Try full demo” on home instead)
# VITE_DEMO_MODE=true

# Roman Urdu expense parsing (DeepSeek)
VITE_DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional fallback
VITE_GEMINI_API_KEY=
